<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>QR Validator</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html5-qrcode/2.3.8/html5-qrcode.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;600;800&display=swap');

  :root {
    --bg: #050a0e;
    --surface: #0d1b24;
    --card: #0f2030;
    --accent: #00e5ff;
    --accent2: #00ff9d;
    --danger: #ff3b5c;
    --warn: #ffb400;
    --text: #cfe8f5;
    --muted: #4a7a9b;
    --border: rgba(0,229,255,0.15);
    --glow: 0 0 20px rgba(0,229,255,0.3);
    --glow-green: 0 0 20px rgba(0,255,157,0.4);
    --glow-red: 0 0 20px rgba(255,59,92,0.4);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  body {
    font-family: 'Exo 2', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* Animated grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    z-index: 0;
    pointer-events: none;
  }

  body::after {
    content: '';
    position: fixed;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(ellipse at 60% 20%, rgba(0,229,255,0.05) 0%, transparent 50%),
                radial-gradient(ellipse at 20% 80%, rgba(0,255,157,0.04) 0%, transparent 40%);
    z-index: 0;
    pointer-events: none;
    animation: ambientShift 12s ease-in-out infinite alternate;
  }

  @keyframes ambientShift {
    from { transform: translate(0,0); }
    to { transform: translate(3%, 2%); }
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 480px;
    margin: 0 auto;
    padding: 20px 16px 40px;
  }

  /* Header */
  header {
    text-align: center;
    margin-bottom: 28px;
    padding-top: 12px;
  }

  .logo-icon {
    width: 52px;
    height: 52px;
    margin: 0 auto 10px;
    position: relative;
  }

  .logo-icon svg { width: 100%; height: 100%; }

  .logo-pulse {
    position: absolute;
    inset: -6px;
    border: 1px solid var(--accent);
    border-radius: 12px;
    animation: logoPulse 2.5s ease-in-out infinite;
    opacity: 0.4;
  }

  @keyframes logoPulse {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.12); opacity: 0.1; }
  }

  header h1 {
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  header p {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* Status bar */
  .status-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 14px;
    margin-bottom: 18px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--muted);
    flex-shrink: 0;
    transition: background 0.3s, box-shadow 0.3s;
  }

  .status-dot.active {
    background: var(--accent2);
    box-shadow: 0 0 8px var(--accent2);
    animation: dotPulse 1.2s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .status-text { flex: 1; }

  /* Camera section */
  .camera-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 18px;
    position: relative;
  }

  .camera-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
  }

  .camera-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .cam-badge {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    background: rgba(0,229,255,0.06);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 3px 8px;
  }

  #reader-wrapper {
    position: relative;
    background: #000;
    min-height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #reader {
    width: 100% !important;
  }

  #reader video {
    border-radius: 0 !important;
    width: 100% !important;
    height: auto !important;
  }

  /* Scanning overlay frame */
  .scan-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  .scan-frame {
    width: 180px;
    height: 180px;
    position: relative;
  }

  .scan-frame::before, .scan-frame::after,
  .scan-corner-br, .scan-corner-bl {
    content: '';
    position: absolute;
    width: 28px;
    height: 28px;
    border-color: var(--accent);
    border-style: solid;
  }

  .scan-frame::before { top: 0; left: 0; border-width: 3px 0 0 3px; border-radius: 4px 0 0 0; }
  .scan-frame::after  { top: 0; right: 0; border-width: 3px 3px 0 0; border-radius: 0 4px 0 0; }
  .scan-corner-br     { bottom: 0; right: 0; border-width: 0 3px 3px 0; border-radius: 0 0 4px 0; }
  .scan-corner-bl     { bottom: 0; left: 0; border-width: 0 0 3px 3px; border-radius: 0 0 0 4px; }

  .scan-line {
    position: absolute;
    left: 3px;
    right: 3px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    top: 10%;
    animation: scanLine 2.2s ease-in-out infinite;
    box-shadow: 0 0 8px var(--accent);
  }

  @keyframes scanLine {
    0%   { top: 10%; opacity: 1; }
    45%  { top: 85%; opacity: 1; }
    50%  { opacity: 0; }
    55%  { top: 10%; opacity: 0; }
    60%  { opacity: 1; }
    100% { top: 85%; opacity: 1; }
  }

  .camera-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 40px 20px;
    color: var(--muted);
    text-align: center;
  }

  .camera-placeholder svg { opacity: 0.3; }
  .camera-placeholder p { font-size: 0.8rem; line-height: 1.5; }

  /* Buttons */
  .btn-primary {
    width: 100%;
    padding: 15px;
    background: linear-gradient(135deg, rgba(0,229,255,0.12), rgba(0,255,157,0.08));
    border: 1px solid var(--accent);
    border-radius: 14px;
    color: var(--accent);
    font-family: 'Exo 2', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.25s;
    box-shadow: var(--glow);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .btn-primary:active { transform: scale(0.97); opacity: 0.85; }

  .btn-primary.scanning {
    border-color: var(--danger);
    color: var(--danger);
    background: linear-gradient(135deg, rgba(255,59,92,0.1), rgba(255,59,92,0.05));
    box-shadow: var(--glow-red);
  }

  .btn-secondary {
    width: 100%;
    padding: 12px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 14px;
    color: var(--muted);
    font-family: 'Exo 2', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.25s;
    margin-top: 10px;
  }

  .btn-secondary:active { opacity: 0.7; }

  /* Result overlay */
  .result-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0 0 30px;
    background: rgba(5,10,14,0.85);
    backdrop-filter: blur(6px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s;
  }

  .result-overlay.show {
    opacity: 1;
    pointer-events: all;
  }

  .result-card {
    width: 100%;
    max-width: 440px;
    margin: 0 16px;
    background: var(--card);
    border-radius: 24px;
    overflow: hidden;
    transform: translateY(60px);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 1px solid var(--border);
  }

  .result-overlay.show .result-card {
    transform: translateY(0);
  }

  .result-header {
    padding: 20px 20px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .result-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .result-icon.valid   { background: rgba(0,255,157,0.12); box-shadow: var(--glow-green); }
  .result-icon.invalid { background: rgba(255,59,92,0.12);  box-shadow: var(--glow-red); }

  .result-title {
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .result-title.valid   { color: var(--accent2); }
  .result-title.invalid { color: var(--danger); }

  .result-subtitle {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 2px;
  }

  .result-body {
    padding: 0 20px 16px;
  }

  .result-code-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    color: var(--text);
    word-break: break-all;
    margin-bottom: 14px;
  }

  .result-code-label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 5px;
  }

  .result-message {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text);
    margin-bottom: 16px;
    padding: 12px 14px;
    border-radius: 10px;
  }

  .result-message.valid   { background: rgba(0,255,157,0.07);  border-left: 3px solid var(--accent2); }
  .result-message.invalid { background: rgba(255,59,92,0.07);   border-left: 3px solid var(--danger); }

  .result-meta {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }

  .meta-chip {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 10px;
    text-align: center;
  }

  .meta-chip .label { font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }
  .meta-chip .value { font-family: 'Share Tech Mono', monospace; font-size: 0.78rem; color: var(--text); margin-top: 2px; }

  .btn-close {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, rgba(0,229,255,0.08), rgba(0,229,255,0.04));
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--accent);
    font-family: 'Exo 2', sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-close:active { opacity: 0.7; }

  /* DB Section */
  .section-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    margin-top: 18px;
  }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
  }

  .section-head-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .db-count {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    background: rgba(0,229,255,0.06);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2px 10px;
  }

  .chevron {
    font-size: 0.8rem;
    color: var(--muted);
    transition: transform 0.3s;
  }

  .chevron.open { transform: rotate(180deg); }

  .section-body {
    display: none;
    padding: 14px;
  }

  .section-body.open { display: block; }

  /* Add form */
  .add-form {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
  }

  .add-input {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 11px 13px;
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.82rem;
    outline: none;
    transition: border-color 0.2s;
    text-transform: uppercase;
  }

  .add-input::placeholder { color: var(--muted); text-transform: none; }
  .add-input:focus { border-color: var(--accent); }

  .btn-add {
    padding: 11px 16px;
    background: linear-gradient(135deg, rgba(0,229,255,0.15), rgba(0,255,157,0.1));
    border: 1px solid var(--accent);
    border-radius: 10px;
    color: var(--accent);
    font-family: 'Exo 2', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }

  .btn-add:active { opacity: 0.7; }

  /* DB list */
  .db-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 220px;
    overflow-y: auto;
  }

  .db-list::-webkit-scrollbar { width: 4px; }
  .db-list::-webkit-scrollbar-track { background: var(--surface); }
  .db-list::-webkit-scrollbar-thumb { background: var(--muted); border-radius: 4px; }

  .db-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 9px 12px;
    gap: 8px;
  }

  .db-item-code {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.78rem;
    color: var(--text);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .btn-delete {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 1rem;
    cursor: pointer;
    padding: 2px 4px;
    line-height: 1;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .btn-delete:hover { color: var(--danger); }

  /* History */
  .history-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 200px;
    overflow-y: auto;
  }

  .history-list::-webkit-scrollbar { width: 4px; }
  .history-list::-webkit-scrollbar-track { background: var(--surface); }
  .history-list::-webkit-scrollbar-thumb { background: var(--muted); border-radius: 4px; }

  .history-item {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 9px 12px;
  }

  .history-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .history-dot.valid   { background: var(--accent2); }
  .history-dot.invalid { background: var(--danger); }

  .history-code {
    flex: 1;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.73rem;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .history-time {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.62rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .empty-state {
    text-align: center;
    color: var(--muted);
    font-size: 0.78rem;
    padding: 20px;
    font-family: 'Share Tech Mono', monospace;
  }

  /* Ripple on scan */
  .scan-ripple {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 20;
    display: none;
  }

  .scan-ripple.active { display: block; animation: scanRipple 0.5s ease-out forwards; }

  @keyframes scanRipple {
    0%   { background: rgba(0,229,255,0.2); }
    100% { background: transparent; }
  }
</style>
</head>
<body>
<div class="container">

  <!-- Header -->
  <header>
    <div class="logo-icon">
      <div class="logo-pulse"></div>
      <svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="4" y="4" width="18" height="18" rx="2" stroke="#00e5ff" stroke-width="2"/>
        <rect x="8" y="8" width="10" height="10" fill="#00e5ff" fill-opacity="0.4"/>
        <rect x="30" y="4" width="18" height="18" rx="2" stroke="#00e5ff" stroke-width="2"/>
        <rect x="34" y="8" width="10" height="10" fill="#00e5ff" fill-opacity="0.4"/>
        <rect x="4" y="30" width="18" height="18" rx="2" stroke="#00e5ff" stroke-width="2"/>
        <rect x="8" y="34" width="10" height="10" fill="#00e5ff" fill-opacity="0.4"/>
        <rect x="30" y="30" width="5" height="5" fill="#00ff9d"/>
        <rect x="37" y="30" width="5" height="5" fill="#00ff9d"/>
        <rect x="30" y="37" width="5" height="5" fill="#00ff9d"/>
        <rect x="37" y="37" width="11" height="11" rx="1" fill="#00ff9d" fill-opacity="0.5"/>
      </svg>
    </div>
    <h1>QR Validator</h1>
    <p>Sistema de control de acceso · v2.1</p>
  </header>

  <!-- Status bar -->
  <div class="status-bar">
    <div class="status-dot" id="statusDot"></div>
    <span class="status-text" id="statusText">Sistema listo — presiona escanear</span>
  </div>

  <!-- Camera card -->
  <div class="camera-card">
    <div class="camera-header">
      <span class="camera-label">&#9654; Lector de cámara</span>
      <span class="cam-badge" id="camBadge">CAM INACTIVA</span>
    </div>
    <div id="reader-wrapper">
      <div id="reader"></div>
      <div class="scan-overlay" id="scanOverlay" style="display:none;">
        <div class="scan-frame">
          <div class="scan-corner-br"></div>
          <div class="scan-corner-bl"></div>
          <div class="scan-line"></div>
        </div>
      </div>
      <div class="scan-ripple" id="scanRipple"></div>
      <div class="camera-placeholder" id="cameraPlaceholder">
        <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
          <path d="M20 10H10a2 2 0 0 0-2 2v10M36 10h10a2 2 0 0 1 2 2v10M20 46H10a2 2 0 0 1-2-2V34M36 46h10a2 2 0 0 0 2-2V34" stroke="#4a7a9b" stroke-width="2.5" stroke-linecap="round"/>
          <circle cx="28" cy="28" r="8" stroke="#4a7a9b" stroke-width="2"/>
          <circle cx="28" cy="28" r="3" fill="#4a7a9b" fill-opacity="0.4"/>
        </svg>
        <p>Activa la cámara para<br>escanear un código QR</p>
      </div>
    </div>
  </div>

  <!-- Scan button -->
  <button class="btn-primary" id="scanBtn" onclick="toggleScan()">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M3 7V5a2 2 0 0 1 2-2h2M17 3h2a2 2 0 0 1 2 2v2M21 17v2a2 2 0 0 1-2 2h-2M7 21H5a2 2 0 0 1-2-2v-2"/>
      <rect x="7" y="7" width="10" height="10" rx="1"/>
    </svg>
    <span id="scanBtnText">Iniciar Escaneo</span>
  </button>

  <!-- DB Section -->
  <div class="section-card">
    <div class="section-head" onclick="toggleSection('db')">
      <div class="section-head-left">
        <span class="section-title">&#128197; Base de Datos</span>
        <span class="db-count" id="dbCount">15 códigos</span>
      </div>
      <span class="chevron" id="dbChevron">&#9660;</span>
    </div>
    <div class="section-body" id="dbBody">
      <div class="add-form">
        <input class="add-input" id="newCode" placeholder="Ingresa código nuevo..." maxlength="40" oninput="this.value = this.value.toUpperCase()">
        <button class="btn-add" onclick="addCode()">+ Agregar</button>
      </div>
      <div class="db-list" id="dbList"></div>
    </div>
  </div>

  <!-- History Section -->
  <div class="section-card">
    <div class="section-head" onclick="toggleSection('hist')">
      <div class="section-head-left">
        <span class="section-title">&#128338; Historial</span>
        <span class="db-count" id="histCount">0 escaneos</span>
      </div>
      <span class="chevron" id="histChevron">&#9660;</span>
    </div>
    <div class="section-body" id="histBody">
      <div class="history-list" id="histList">
        <p class="empty-state">Sin escaneos aún</p>
      </div>
    </div>
  </div>

</div>

<!-- Result overlay -->
<div class="result-overlay" id="resultOverlay" onclick="closeResult(event)">
  <div class="result-card" onclick="event.stopPropagation()">
    <div class="result-header">
      <div class="result-icon" id="resultIcon"></div>
      <div>
        <div class="result-title" id="resultTitle"></div>
        <div class="result-subtitle" id="resultSubtitle"></div>
      </div>
    </div>
    <div class="result-body">
      <div class="result-code-box">
        <div class="result-code-label">Código escaneado</div>
        <div id="resultCode"></div>
      </div>
      <div class="result-message" id="resultMessage"></div>
      <div class="result-meta">
        <div class="meta-chip">
          <div class="label">Estado</div>
          <div class="value" id="metaStatus"></div>
        </div>
        <div class="meta-chip">
          <div class="label">Hora</div>
          <div class="value" id="metaTime"></div>
        </div>
        <div class="meta-chip">
          <div class="label">Total BD</div>
          <div class="value" id="metaDb"></div>
        </div>
      </div>
      <button class="btn-close" onclick="closeResult()">Continuar Escaneando</button>
    </div>
  </div>
</div>

<script>
// ─── Database ────────────────────────────────────────────────────────────────
let qrDatabase = [
  "A3K9-XM72-PQ41","BT56-NR18-WZ93","CY84-LH37-VF62",
  "DG21-SK95-JU48","EQ73-OB64-MT15","FW39-IC82-AH57",
  "GN16-ZD43-RK90","HU52-YP71-SB28","IJ87-WE56-NQ34",
  "KX44-FM19-TC76","LR60-AV93-DG21","MO35-KT48-EH87",
  "NB91-SQ27-IL53","OD78-RN64-UJ12","PC23-HZ80-YM45"
];

let scanHistory = [];
let scanner = null;
let isScanning = false;

// ─── Init ─────────────────────────────────────────────────────────────────────
renderDB();

// ─── Scanner ──────────────────────────────────────────────────────────────────
async function toggleScan() {
  if (!isScanning) {
    await startScan();
  } else {
    await stopScan();
  }
}

async function startScan() {
  try {
    scanner = new Html5Qrcode("reader");
    await scanner.start(
      { facingMode: "environment" },
      { fps: 10, qrbox: { width: 200, height: 200 } },
      onScanSuccess,
      () => {}
    );
    isScanning = true;
    document.getElementById('cameraPlaceholder').style.display = 'none';
    document.getElementById('scanOverlay').style.display = 'flex';
    document.getElementById('scanBtn').classList.add('scanning');
    document.getElementById('scanBtnText').textContent = 'Detener Escaneo';
    document.getElementById('statusDot').classList.add('active');
    document.getElementById('statusText').textContent = 'Cámara activa — apunta al código QR';
    document.getElementById('camBadge').textContent = 'CAM ACTIVA';
  } catch(e) {
    setStatus('Error al acceder a la cámara');
  }
}

async function stopScan() {
  if (scanner && isScanning) {
    try { await scanner.stop(); } catch(e) {}
    scanner = null;
  }
  isScanning = false;
  document.getElementById('cameraPlaceholder').style.display = 'flex';
  document.getElementById('scanOverlay').style.display = 'none';
  document.getElementById('scanBtn').classList.remove('scanning');
  document.getElementById('scanBtnText').textContent = 'Iniciar Escaneo';
  document.getElementById('statusDot').classList.remove('active');
  document.getElementById('statusText').textContent = 'Sistema listo — presiona escanear';
  document.getElementById('camBadge').textContent = 'CAM INACTIVA';
}

function onScanSuccess(decodedText) {
  // Ripple effect
  const ripple = document.getElementById('scanRipple');
  ripple.classList.remove('active');
  void ripple.offsetWidth;
  ripple.classList.add('active');

  const code = decodedText.trim().toUpperCase();
  const isValid = qrDatabase.includes(code);
  const now = new Date();
  const timeStr = now.toLocaleTimeString('es-MX', {hour:'2-digit', minute:'2-digit', second:'2-digit'});

  // Add to history
  scanHistory.unshift({ code, valid: isValid, time: timeStr });
  renderHistory();

  // Show result
  showResult(code, isValid, timeStr);

  // Vibrate
  if (navigator.vibrate) navigator.vibrate(isValid ? [80, 40, 80] : [200]);
}

// ─── Result Modal ─────────────────────────────────────────────────────────────
function showResult(code, isValid, timeStr) {
  const icon  = document.getElementById('resultIcon');
  const title = document.getElementById('resultTitle');
  const sub   = document.getElementById('resultSubtitle');
  const msg   = document.getElementById('resultMessage');
  const rc    = document.getElementById('resultCode');
  const ms    = document.getElementById('metaStatus');
  const mt    = document.getElementById('metaTime');
  const mdb   = document.getElementById('metaDb');

  icon.className  = `result-icon ${isValid ? 'valid' : 'invalid'}`;
  icon.textContent = isValid ? '✅' : '❌';
  title.className = `result-title ${isValid ? 'valid' : 'invalid'}`;
  title.textContent = isValid ? 'Acceso Permitido' : 'Acceso Denegado';
  sub.textContent   = isValid ? 'Código QR reconocido en el sistema' : 'Código QR no registrado';
  rc.textContent    = code;
  msg.className     = `result-message ${isValid ? 'valid' : 'invalid'}`;
  msg.textContent   = isValid
    ? '✔ El código QR es válido y se encuentra registrado en la base de datos. Acceso autorizado.'
    : '✘ El código QR escaneado no existe en la base de datos. Acceso no autorizado.';
  ms.textContent    = isValid ? 'VÁLIDO' : 'INVÁLIDO';
  mt.textContent    = timeStr;
  mdb.textContent   = `${qrDatabase.length}`;

  const overlay = document.getElementById('resultOverlay');
  overlay.classList.add('show');
}

function closeResult(e) {
  if (e && e.target !== document.getElementById('resultOverlay')) return;
  document.getElementById('resultOverlay').classList.remove('show');
  setStatus('Listo para el siguiente escaneo');
}

document.getElementById('resultOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeResult(e);
});

// ─── DB Management ────────────────────────────────────────────────────────────
function renderDB() {
  const list = document.getElementById('dbList');
  document.getElementById('dbCount').textContent = `${qrDatabase.length} códigos`;
  if (!qrDatabase.length) {
    list.innerHTML = '<p class="empty-state">Base de datos vacía</p>';
    return;
  }
  list.innerHTML = qrDatabase.map((c, i) => `
    <div class="db-item">
      <span class="db-item-code">${c}</span>
      <button class="btn-delete" onclick="deleteCode(${i})" title="Eliminar">&#10005;</button>
    </div>
  `).join('');
}

function addCode() {
  const inp = document.getElementById('newCode');
  const val = inp.value.trim();
  if (!val) return;
  if (qrDatabase.includes(val)) {
    inp.style.borderColor = 'var(--warn)';
    setTimeout(() => inp.style.borderColor = '', 1200);
    return;
  }
  qrDatabase.push(val);
  inp.value = '';
  renderDB();
  setStatus(`Código "${val}" agregado a la base de datos`);
}

function deleteCode(i) {
  qrDatabase.splice(i, 1);
  renderDB();
}

document.getElementById('newCode').addEventListener('keydown', e => {
  if (e.key === 'Enter') addCode();
});

// ─── History ──────────────────────────────────────────────────────────────────
function renderHistory() {
  const list = document.getElementById('histList');
  document.getElementById('histCount').textContent = `${scanHistory.length} escaneos`;
  if (!scanHistory.length) {
    list.innerHTML = '<p class="empty-state">Sin escaneos aún</p>';
    return;
  }
  list.innerHTML = scanHistory.slice(0,30).map(h => `
    <div class="history-item">
      <div class="history-dot ${h.valid ? 'valid' : 'invalid'}"></div>
      <span class="history-code">${h.code}</span>
      <span class="history-time">${h.time}</span>
    </div>
  `).join('');
}

// ─── Sections toggle ──────────────────────────────────────────────────────────
function toggleSection(id) {
  const body    = document.getElementById(id === 'db' ? 'dbBody' : 'histBody');
  const chevron = document.getElementById(id === 'db' ? 'dbChevron' : 'histChevron');
  body.classList.toggle('open');
  chevron.classList.toggle('open');
}

// ─── Utils ────────────────────────────────────────────────────────────────────
function setStatus(msg) {
  document.getElementById('statusText').textContent = msg;
}
</script>
</body>
</html>
